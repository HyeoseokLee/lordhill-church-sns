{
  "name": "lordhill-church-sns",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:app": "npm run dev --workspace=packages/app-front",
    "dev:admin": "npm run dev --workspace=packages/admin-front",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:app\"",
    "build:app": "npm run build --workspace=packages/app-front",
    "build:admin": "npm run build --workspace=packages/admin-front"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
